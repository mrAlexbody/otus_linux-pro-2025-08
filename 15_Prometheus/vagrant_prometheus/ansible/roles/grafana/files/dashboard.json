{
  "title": "Александр",
  "panels": [
    {
      "title": "Memory Usage",
      "targets": [{"expr": "100 - ((node_memory_MemFree_bytes+node_memory_Cached_bytes+node_memory_Buffers_bytes)/node_memory_MemTotal_bytes * 100)"}],
      "type": "graph"
    },
    {
      "title": "CPU Usage",
      "targets": [{"expr": "100 - (avg(rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)"}],
      "type": "graph"
    },
    {
      "title": "Disk Usage",
      "targets": [{"expr": "100 - ((node_filesystem_free_bytes{mountpoint='/'} / node_filesystem_size_bytes{mountpoint='/'}) * 100)"}],
      "type": "graph"
    },
    {
      "title": "Network Traffic",
      "targets": [
        {"expr": "rate(node_network_receive_bytes_total[5m])", "legendFormat": "rx"},
        {"expr": "rate(node_network_transmit_bytes_total[5m])", "legendFormat": "tx"}
      ],
      "type": "graph"
    }
  ]
}

