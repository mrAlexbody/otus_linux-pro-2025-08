[all:vars]
ansible_host=127.0.0.1
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'
ansible_user=vagrant
ansible_python_interpreter=/usr/bin/python3

[lb]
lb1 ansible_host=192.168.77.11 ansible_user=vagrant ansible_ssh_private_key_file=./.vagrant/machines/lb1/virtualbox/private_key
lb2 ansible_host=192.168.77.12 ansible_user=vagrant ansible_ssh_private_key_file=./.vagrant/machines/lb2/virtualbox/private_key

