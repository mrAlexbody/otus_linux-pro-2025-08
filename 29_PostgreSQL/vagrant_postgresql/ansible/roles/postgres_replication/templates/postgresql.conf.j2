# Файл конфигурации PostgreSQL
data_directory = '/var/lib/postgresql/14/main'
hba_file = '/etc/postgresql/14/main/pg_hba.conf'
ident_file = '/etc/postgresql/14/main/pg_ident.conf'

# Слушаем localhost и IP хоста
{% if ansible_hostname == 'master' %}
listen_addresses = 'localhost, {{ master_ip }}'
{% elif ansible_hostname == 'slave' %}
listen_addresses = 'localhost, {{ slave_ip }}'
{% endif %}

port = 5432 
max_connections = 100

# Логирование
log_directory = 'log' 
log_filename = 'postgresql-%a.log' 
log_rotation_age = 1d 
log_rotation_size = 0 
log_truncate_on_rotation = on 
log_line_prefix = '%m [%p] ' 
log_timezone = 'UTC+3'
timezone = 'UTC+3'
datestyle = 'iso, mdy'
lc_messages = 'en_US.UTF-8'
lc_monetary = 'en_US.UTF-8' 
lc_numeric = 'en_US.UTF-8' 
lc_time = 'en_US.UTF-8' 
default_text_search_config = 'pg_catalog.english'

# Настройки репликации
max_wal_size = 1GB
min_wal_size = 80MB
hot_standby = on
wal_level = replica
max_wal_senders = 3
max_replication_slots = 3
hot_standby_feedback = on
password_encryption = scram-sha-256

# Включаем режим архивации
archive_mode = on

# Команда для отправки WAL-файлов на сервер Barman через rsync
archive_command = 'rsync -a %p barman@192.168.77.152:/var/lib/barman/master/incoming/%f'

# Время, через которое файл принудительно архивируется, даже если он не заполнился (опционально)
archive_timeout = 60